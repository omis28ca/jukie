PORT=3000
DATABASE_URL="file:./dev.db"
UPLOAD_DIR="../../storage/uploads"
ARTWORK_DIR="../../storage/artwork"
ADMIN_PIN="1234"
MAX_UPLOAD_MB=5120
ALLOWED_AUDIO_EXTENSIONS=".mp3,.wav,.m4a,.flac"
# Full path to mpv binary — omit if mpv is already on PATH
# Windows example: PLAYER_EXEC=C:\tools\mpv\mpv.exe
# Ubuntu: leave unset (mpv from apt is on PATH)
PLAYER_EXEC=
# Full path to ffprobe binary — omit if ffprobe is already on PATH
# Windows example: AUDIO_PROBE_EXEC=C:\tools\ffmpeg\bin\ffprobe.exe
AUDIO_PROBE_EXEC=
# Full path to ffmpeg binary used for extracting embedded artwork
# Windows example: AUDIO_TRANSCODE_EXEC=C:\tools\ffmpeg\bin\ffmpeg.exe
AUDIO_TRANSCODE_EXEC=
