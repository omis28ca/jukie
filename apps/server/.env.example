PORT=3000
DATABASE_URL="file:./dev.db"
UPLOAD_DIR="../../storage/uploads"
ADMIN_PIN="change-me"
MAX_UPLOAD_MB=100
ALLOWED_AUDIO_EXTENSIONS=".mp3,.wav,.m4a,.flac"
# Full path to mpv binary — omit if mpv is already on PATH
# Windows example: PLAYER_EXEC=C:\tools\mpv\mpv.exe
# Ubuntu: leave unset (mpv from apt is on PATH)
PLAYER_EXEC=
