# Base URL for REST API calls.
# Leave empty to use the same origin as the frontend (default for production).
# Set to the backend dev server when running frontend and backend separately.
VITE_API_BASE=http://localhost:3000

# Base URL for the Socket.IO connection.
# Defaults to VITE_API_BASE if not set.
# Override only if your WebSocket server runs on a different host/port.
VITE_SOCKET_URL=http://localhost:3000

